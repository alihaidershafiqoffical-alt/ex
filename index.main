
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IVD — Infinity Video Downloader | Download video & audio in up to 8K</title>
  <meta name="description"
    content="IVD is a desktop app for downloading video and audio from YouTube, Instagram, TikTok, Facebook and more — up to native 8K quality, or audio-only.">
  <link rel="icon" href="assets/favicon.png" type="image/png">

  <!-- Two free Google Fonts: Space Grotesk (display/headings) + Inter (body). -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    rel="stylesheet">

  <!-- Shared stylesheet + script, cached once and reused by every page. -->
  <link rel="stylesheet" href="assets/styles.css">
</head>

<body data-page="home">

  <!-- =================== NAVBAR (same on every page) =================== -->
  <nav class="navbar">
    <a href="index.html#home" class="brand">
      <img src="assets/logo.png" alt="IVD logo">
      <span class="brand-name">IVD</span>
    </a>
    <button class="nav-toggle" aria-label="Toggle menu"><span></span><span></span><span></span></button>
    <div class="nav-links">
      <a href="index.html#home" class="nav-link" data-page="home">Home</a>
      <a href="index.html#pricing" class="nav-link">Pricing</a>
      <a href="index.html#faq" class="nav-link">FAQ</a>
      <a href="contact.html" class="nav-link" data-page="contact">Support</a>
      <!-- TODO: replace the href below with your actual installer/download link -->
      <a href="https://your-download-link.com/IVD-Setup.exe" target="_blank" rel="noopener"
        class="btn btn-primary btn-sm">Download Now</a>
    </div>
  </nav>

  <!-- =================== HERO =================== -->
  <header class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Desktop app for Windows &amp; macOS</span>
        <h1>Every video. Every platform. No limits.</h1>
        <p class="lede">IVD saves video and audio from YouTube, Instagram, TikTok, Facebook, and hundreds of other
          platforms — up to native 8K resolution, or audio-only when that's all you need.</p>
        <div class="hero-cta-row">
          <!-- TODO: replace the href below with your actual installer/download link -->
          <a href="https://your-download-link.com/IVD-Setup.exe" target="_blank" rel="noopener"
            class="btn btn-primary">Download Now</a>
          <span class="hero-note">Free plan available · Windows &amp; macOS</span>
        </div>
      </div>

      <!-- Decorative glossy "orb" accents filling the empty space around the hero art. Purely visual; hidden on small screens. -->
      <div class="orb-decor orb orb--sm" style="width:52px;height:52px;top:8%;left:6%;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <path d="M9 18V5l9-2v13"></path>
          <circle cx="6" cy="18" r="2.4"></circle>
          <circle cx="15" cy="16" r="2.4"></circle>
        </svg>
      </div>
      <div class="orb-decor orb" style="width:70px;height:70px;bottom:6%;left:34%;">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <rect x="3" y="7" width="12" height="10" rx="2"></rect>
          <path d="M15 10l6-3v10l-6-3z"></path>
        </svg>
      </div>

      <div class="hero-visual">
        <div
          style="width: 320px; background: #FFFFFF; border: 1px solid var(--color-border); border-radius: 16px; padding: 26px; box-shadow: var(--shadow-lift); position: relative; z-index: 1;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <span style="font-size:12px; font-weight:600; color:var(--color-body);">DOWNLOADING</span>
            <span style="width:8px;height:8px;border-radius:50%;background:var(--color-primary);"></span>
          </div>
          <div
            style="font-size:15px; font-weight:600; margin-bottom:14px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            weekend-hike-highlights.mp4</div>
          <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
            <span
              style="background:var(--color-primary); color:#fff; font-size:12px; font-weight:600; padding:5px 10px; border-radius:6px;">8K</span>
            <span
              style="background:var(--color-surface-alt); color:var(--color-body); font-size:12px; font-weight:600; padding:5px 10px; border-radius:6px;">4K</span>
            <span
              style="background:var(--color-surface-alt); color:var(--color-body); font-size:12px; font-weight:600; padding:5px 10px; border-radius:6px;">Audio
              only</span>
          </div>
          <div
            style="width:100%; height:8px; background:var(--color-surface-alt); border-radius:4px; overflow:hidden; margin-bottom:10px;">
            <div style="width:68%; height:100%; background:var(--color-primary); border-radius:4px;"></div>
          </div>
          <div style="font-size:13px; color:var(--color-body);">68% · 42 MB/s</div>
        </div>
      </div>
    </div>
  </header>

  <!-- =================== CAROUSEL: software previews =================== -->
  <section class="carousel-section">
    <div class="container">
      <div class="carousel">
        <div class="carousel-viewport">
          <div class="carousel-track">

            <div class="carousel-slide">
              <div class="slide-window">
                <div class="slide-window-bar"><span class="slide-dot-btn"></span><span
                    class="slide-dot-btn"></span><span class="slide-dot-btn"></span></div>
                <div
                  style="display:flex; align-items:center; gap:12px; background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px; padding:12px 16px;">
                  <span style="color:var(--color-muted); font-size:14px;">Paste a link from any platform…</span>
                  <span class="btn btn-primary btn-sm" style="margin-left:auto;">Fetch</span>
                </div>
              </div>
              <div class="carousel-caption">
                <h3>Paste any link</h3>
                <p>Drop in a URL from YouTube, Instagram, TikTok, or almost anywhere else — IVD finds the video
                  automatically.</p>
              </div>
            </div>

            <div class="carousel-slide">
              <div class="slide-window">
                <div class="slide-window-bar"><span class="slide-dot-btn"></span><span
                    class="slide-dot-btn"></span><span class="slide-dot-btn"></span></div>
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                  <span
                    style="background:var(--color-primary); color:#fff; font-size:13px; font-weight:600; padding:8px 14px; border-radius:8px;">8K</span>
                  <span
                    style="background:var(--color-surface); border:1px solid var(--color-border); font-size:13px; font-weight:600; padding:8px 14px; border-radius:8px;">4K</span>
                  <span
                    style="background:var(--color-surface); border:1px solid var(--color-border); font-size:13px; font-weight:600; padding:8px 14px; border-radius:8px;">1080p</span>
                  <span
                    style="background:var(--color-surface); border:1px solid var(--color-border); font-size:13px; font-weight:600; padding:8px 14px; border-radius:8px;">Audio
                    only</span>
                </div>
              </div>
              <div class="carousel-caption">
                <h3>Choose your quality</h3>
                <p>Keep the original resolution up to full 8K, or pick something lighter — the choice is always yours.
                </p>
              </div>
            </div>

            <div class="carousel-slide">
              <div class="slide-window">
                <div class="slide-window-bar"><span class="slide-dot-btn"></span><span
                    class="slide-dot-btn"></span><span class="slide-dot-btn"></span></div>
                <div style="display:flex; flex-direction:column; gap:8px;">
                  <div style="display:flex; align-items:center; gap:10px; font-size:13px; color:var(--color-body);">
                    <span
                      style="width:6px;height:6px;border-radius:50%;background:var(--color-primary);"></span>tutorial-part-1.mp4
                    — queued</div>
                  <div style="display:flex; align-items:center; gap:10px; font-size:13px; color:var(--color-body);">
                    <span
                      style="width:6px;height:6px;border-radius:50%;background:var(--color-primary);"></span>tutorial-part-2.mp4
                    — queued</div>
                  <div
                    style="display:flex; align-items:center; gap:10px; font-size:13px; color:var(--color-ink); font-weight:600;">
                    <span
                      style="width:6px;height:6px;border-radius:50%;background:var(--color-primary);"></span>tutorial-part-3.mp4
                    — downloading</div>
                </div>
              </div>
              <div class="carousel-caption">
                <h3>Queue in batches</h3>
                <p>Line up several links at once and let IVD work through them in the background.</p>
              </div>
            </div>

            <div class="carousel-slide">
              <div class="slide-window">
                <div class="slide-window-bar"><span class="slide-dot-btn"></span><span
                    class="slide-dot-btn"></span><span class="slide-dot-btn"></span></div>
                <div style="display:flex; align-items:center; gap:14px;">
                  <div class="orb" style="width:44px;height:44px;position:static;"><svg width="18" height="18"
                      viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M9 18V5l9-2v13"></path>
                      <circle cx="6" cy="18" r="2.4"></circle>
                      <circle cx="15" cy="16" r="2.4"></circle>
                    </svg></div>
                  <div>
                    <div style="font-size:14px; font-weight:600;">morning-podcast-clip.mp3</div>
                    <div style="font-size:12px; color:var(--color-body);">Audio extracted · 192 kbps</div>
                  </div>
                </div>
              </div>
              <div class="carousel-caption">
                <h3>Audio, on its own</h3>
                <p>Pull just the sound as MP3 or M4A when the video part isn't what you need.</p>
              </div>
            </div>

          </div>
        </div>
        <button class="carousel-btn prev" aria-label="Previous preview">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0B1220" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 18l-6-6l6-6"></path>
          </svg>
        </button>
        <button class="carousel-btn next" aria-label="Next preview">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0B1220" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6l-6-6"></path>
          </svg>
        </button>
        <div class="carousel-dots"></div>
      </div>
    </div>
  </section>

  <!-- =================== STATS =================== -->
  <section class="section section-alt" style="padding-top:48px; padding-bottom:48px;">
    <div class="container stats-grid">
      <div>
        <div class="stat-num">2M+</div>
        <div class="stat-label">Downloads completed</div>
      </div>
      <div>
        <div class="stat-num">300+</div>
        <div class="stat-label">Supported platforms</div>
      </div>
      <div>
        <div class="stat-num">8K</div>
        <div class="stat-label">Max download quality</div>
      </div>
      <div>
        <div class="stat-num">4.8★</div>
        <div class="stat-label">Average user rating</div>
      </div>
    </div>
  </section>

  <!-- =================== PRICING =================== -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="section-heading center">
        <h2 class="kicker">Simple pricing, cancel anytime</h2>
        <p class="lede">Start free. Upgrade only if IVD earns a permanent spot on your desktop.</p>
      </div>
      <div class="pricing-grid">

        <div class="price-card">
          <h3 class="price-name">Free</h3>
          <p class="price-tagline">Try it out</p>
          <div class="price-amount">$0</div>
          <ul class="price-features">
            <li>Downloads up to 1080p</li>
            <li>5 downloads per day</li>
            <li>Video downloads only</li>
          </ul>
          <a href="contact.html" class="btn btn-outline">Get started</a>
        </div>

        <div class="price-card price-card--featured">
          <span class="price-badge">Most popular</span>
          <h3 class="price-name" style="margin-top:12px;">Pro</h3>
          <p class="price-tagline">For frequent downloads</p>
          <div class="price-amount">$8<span> / month</span></div>
          <ul class="price-features">
            <li>Downloads up to 8K</li>
            <li>Unlimited downloads</li>
            <li>Audio-only extraction</li>
            <li>Batch downloading</li>
          </ul>
          <a href="contact.html" class="btn btn-primary">Start Pro</a>
        </div>

        <div class="price-card">
          <h3 class="price-name">Lifetime</h3>
          <p class="price-tagline">Pay once, download forever</p>
          <div class="price-amount">$59</div>
          <ul class="price-features">
            <li>Everything in Pro</li>
            <li>Lifetime updates</li>
            <li>Priority email support</li>
          </ul>
          <a href="contact.html" class="btn btn-outline">Buy once</a>
        </div>

      </div>
    </div>
  </section>

  <!-- =================== FAQ =================== -->
  <section class="section section-alt" id="faq">
    <div class="container">
      <div class="section-heading center">
        <h2 class="kicker">Frequently asked questions</h2>
        <p class="lede">Can't find what you're after? The Support page has more detail.</p>
      </div>
      <div class="faq-list">

        <div class="faq-item is-open">
          <button class="faq-question">Is IVD free to use?<span class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Yes — the Free plan lets you download at up to 1080p, five times a day, at no
              cost. Pro and Lifetime remove those limits and unlock 8K and audio-only downloads.</div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">What's the highest video quality IVD supports?<span
              class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">IVD can save video at its original resolution, up to full 8K, on the Pro and
              Lifetime plans. The Free plan is capped at 1080p.</div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Can I download just the audio?<span class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Yes. Choose "Audio only" before downloading and IVD extracts the track as an
              MP3 or M4A file instead of saving the video.</div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Which platforms does IVD support?<span class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Over 300 platforms, including YouTube, Instagram, TikTok, Facebook, and X.
              Paste any supported link and IVD detects it automatically.</div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Does IVD run on both Windows and macOS?<span class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Yes — one license covers both. See the System Requirements section above for
              the minimum specs on each.</div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">What's your refund policy?<span class="faq-icon">+</span></button>
          <div class="faq-answer">
            <div class="faq-answer-inner">Pro and Lifetime purchases can be refunded within 14 days if IVD isn't working
              out for you. Full details are on the <a href="refund.html" style="color:var(--color-primary);">Refund
                Policy</a> page.</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- =================== SYSTEM REQUIREMENTS =================== -->
  <section class="section">
    <div class="container">
      <div class="section-heading center">
        <h2 class="kicker">System requirements</h2>
        <p class="lede">What your machine needs to run IVD comfortably.</p>
      </div>
      <div class="sysreq-grid">

        <div class="sysreq-card">
          <div class="sysreq-head">
            <div class="orb orb--ghost" style="width:40px;height:40px;position:static;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                <line x1="8" y1="20" x2="16" y2="20"></line>
              </svg>
            </div>
            <h3>Windows</h3>
          </div>
          <ul class="sysreq-list">
            <li><span>OS</span><strong>Windows 10 or later</strong></li>
            <li><span>Processor</span><strong>Dual-core 2.0 GHz+</strong></li>
            <li><span>Memory</span><strong>4 GB RAM minimum</strong></li>
            <li><span>Storage</span><strong>500 MB free space</strong></li>
            <li><span>Network</span><strong>Broadband internet</strong></li>
          </ul>
        </div>

        <div class="sysreq-card">
          <div class="sysreq-head">
            <div class="orb orb--ghost" style="width:40px;height:40px;position:static;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"
                stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                <line x1="8" y1="20" x2="16" y2="20"></line>
              </svg>
            </div>
            <h3>macOS</h3>
          </div>
          <ul class="sysreq-list">
            <li><span>OS</span><strong>macOS 12 Monterey or later</strong></li>
            <li><span>Chip</span><strong>Apple Silicon or Intel</strong></li>
            <li><span>Memory</span><strong>4 GB RAM minimum</strong></li>
            <li><span>Storage</span><strong>500 MB free space</strong></li>
            <li><span>Network</span><strong>Broadband internet</strong></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- =================== MOBILE APP TEASER =================== -->
  <section style="padding: 0 0 88px 0;">
    <div class="mobile-banner">
      <div class="orb" style="width:44px;height:44px;position:static;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"
          stroke-linejoin="round">
          <rect x="7" y="2" width="10" height="20" rx="2"></rect>
          <line x1="11" y1="18" x2="13" y2="18"></line>
        </svg>
      </div>
      <p><strong>IVD for mobile is on the way.</strong> We're building iOS and Android apps with the same download tools
        — sign up on the Support page to hear when they launch.</p>
      <span class="tag">Coming soon</span>
    </div>
  </section>

